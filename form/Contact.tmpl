{{ define "Contact" }}
  {{ template "Header" }}
  {{ template "Navbar" }}

<div class="card text-white" style="margin-top: 10px;background: linear-gradient(to bottom, #96def7 0%, #f1b2b0 100%)">
    <div class="card-body" style="font-size: 25px;">Contact Us</div>
  </div>


<div class="container" style="margin-top: 20px;">
  <div class="card-deck">
    <div class="card bg-primary">
      <div class="card-body text-center">
          <h5>Call us</h5>
        <p class="card-text">+919454106859</p>
        
      </div>
    </div>
    <div class="card bg-warning">
      <div class="card-body text-center">
        <h5>Address</h5>
        <p class="card-text">Birgunj,Nepal</p>
      </div>
    </div>
    <div class="card bg-success">
      <div class="card-body text-center">
        <h5>Email</h5>
        <p class="card-text">jainepalmstore@gmail.com</p>
      </div>
    </div>
    <div class="card bg-danger">
      <div class="card-body text-center">
        <h5>Website</h5>
        <p class="card-text">jainepalmachinerystore.com</p>
      </div>
    </div>  
  </div>
</div>




<div class="container" style="padding-top: 20px;">
    <h4 style="margin-top: 10px;">Interested in Our Products? Enquire Now</h4>
  <form class="container border p-3" method="POST" action="/contactus" >
    <div class="form-group">
        <h3>Query form</h3>
          </div>
    
    <div class="form-group">
        <label for="name">Name:</label>
        <input type="text" class="form-control" id="name" placeholder="Enter name" name="name">
      </div>
    <div class="form-group">
      <label for="email">Email:</label>
      <input type="email" class="form-control" id="email" placeholder="Enter email" name="email">
    </div>
    <div class="form-group">
      <label for="comment">Comment:</label>
      <input type="comment" class="form-control" id="comment" placeholder="Enter comment" name="comment">
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
  </form>
</div>

  {{ template "Footer" }}
{{ end }}